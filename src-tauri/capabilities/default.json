{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window and sticky note widgets",
  "windows": ["main", "sticky-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "global-shortcut:default",
    "opener:default",
    "dialog:default",
    "updater:default",
    "process:default"
  ]
}
